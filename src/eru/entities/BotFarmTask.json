{
  "name": "BotFarmTask",
  "type": "object",
  "properties": {
    "title": { "type": "string" },
    "description": { "type": "string" },
    "work_type": {
      "type": "string",
      "enum": ["data_gathering", "analysis", "summarization", "monitoring", "verification", "communications", "security", "sorting", "research", "reporting", "command_support"]
    },
    "priority": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"],
      "default": "medium"
    },
    "status": {
      "type": "string",
      "enum": ["pending", "assigned", "active", "blocked", "review", "complete", "failed", "escalated"],
      "default": "pending"
    },
    "urgency": { "type": "number", "default": 50 },
    "risk": { "type": "number", "default": 20 },
    "expected_output_value": { "type": "number", "default": 50 },
    "bot_fit_score": { "type": "number", "default": 60 },
    "coordination_cost": { "type": "number", "default": 8 },
    "required_specialization": { "type": "string" },
    "assigned_bot_id": { "type": "string" },
    "assigned_squad_id": { "type": "string" },
    "assigned_commander_bot_id": { "type": "string" },
    "mission_id": { "type": "string" },
    "queue_bucket": {
      "type": "string",
      "enum": ["operations", "research", "security", "support", "reporting"],
      "default": "operations"
    },
    "estimated_load": { "type": "number", "default": 20 },
    "progress": { "type": "number", "default": 0 },
    "actual_quality": { "type": "number", "default": 0 },
    "blocked_reason": { "type": "string" }
  },
  "required": ["title", "work_type"],
  "rls": {
    "create": { "created_by": "{{user.email}}" },
    "read": { "created_by": "{{user.email}}" },
    "update": { "created_by": "{{user.email}}" },
    "delete": { "created_by": "{{user.email}}" }
  }
}