{
  "name": "KnowledgeBaseDocument",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "source_type": {
      "type": "string",
      "enum": ["document", "faq", "text"],
      "default": "text"
    },
    "file_name": {
      "type": "string"
    },
    "file_url": {
      "type": "string"
    },
    "mime_type": {
      "type": "string"
    },
    "content": {
      "type": "string"
    },
    "faq_items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "question": {
            "type": "string"
          },
          "answer": {
            "type": "string"
          }
        }
      },
      "default": []
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "linked_bot_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "status": {
      "type": "string",
      "enum": ["active", "archived"],
      "default": "active"
    }
  },
  "required": ["title", "source_type"],
  "rls": {
    "create": {
      "created_by": "{{user.email}}"
    },
    "read": {
      "created_by": "{{user.email}}"
    },
    "update": {
      "created_by": "{{user.email}}"
    },
    "delete": {
      "created_by": "{{user.email}}"
    }
  }
}